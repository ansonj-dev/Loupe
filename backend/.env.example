# ── Gemini ───────────────────────────────────────────────────
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ── Server ───────────────────────────────────────────────────
PORT=3001

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your deployed frontend URL)
# Use * only for local dev
ALLOWED_ORIGINS=*

# ── Limits ───────────────────────────────────────────────────
# Max file size per upload in MB
MAX_FILE_SIZE_MB=10

# Max photos per batch request
MAX_PHOTOS_PER_BATCH=20

# Rate limit: max requests per window per IP
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000
